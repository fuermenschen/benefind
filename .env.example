# benefind environment variables
# Copy this file to .env and fill in your keys.
# .env is gitignored and will never be committed.

# OpenAI API key (required for LLM evaluation step)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Brave Search API (required for website discovery step)
# Get yours at: https://brave.com/search/api/
BRAVE_API_KEY=BSA...

# Firecrawl API key (optional - tertiary search fallback in discover step)
# Get yours at: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-...
